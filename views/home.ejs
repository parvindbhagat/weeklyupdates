<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chrysalis</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #f0f0f0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            padding-top: 120px; /* Adjust for navbar height */
            background-image: url("/images/BG_Home.jpg");
      /* image path */
      background-size: cover;
      /* Ensures the image covers the entire background */
      background-position: center;
      /* Centers the image */
      background-repeat: no-repeat;
      /* Prevents the image from repeating */
      background-attachment: fixed;
      /* Keeps the background fixed during scroll */
        }
        .navbar {
            background-color:var(--primary-color);
            color: white;
            padding: 15px;
            /* text-align: center; */
            width: 100%;
            position: fixed;
            top: 0;
            z-index: 1000;
        }
        .container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
            gap: 1rem;
            width: 90%;
            max-width: 1200px;
        }
        .tile {
            /* border: 1px solid #216b4f; */
            border-radius: 8px;
            padding: 20px;
            text-align: center;
            box-shadow: 0 2px 4px rgba(37, 218, 178, 0.1);
            transition: transform 0.2s;
            aspect-ratio: 1 / 1; /* Makes the tiles square */
        }
        .tile:hover {
            transform: scale(1.1);
        }
        .tile img {
            width: 8rem;
            height: 8rem;
        }
        a{
            text-decoration: none;
        }
        .tile p {
            margin: 10px 0 0;
            font-size: 3rem;
            text-decoration: none;
            color: #f0f0f0;
        }
        @media (min-width: 768px) {
            .container {
                grid-template-columns: repeat(3, 1fr);
                /* height: 80%; */
            }
        }
        @media (max-width: 767px) {
            .container {
                grid-template-columns: 1fr;
                height: 80%;
            }
        }
    </style>
</head>
<body>
    <div class="navbar">
        <a class="navbar-brand" href="/home">
            <img src="/images/logo.png" alt="Chrysalis logo" >
          </a>  
          <% if (canAccessCA) { %>
          <a class="btn" href="/ca" style="margin: 36px; cursor: pointer; float: inline-end;">CA Reports</a> 
          <% } %>
    </div>
    <div class="container">
        <a href="/leap" class="tile">
            <img src="/images/logo-ic.png" alt="Leap Icon">
            <p>LEAP</p>
        </a>
        <a href="https://www.myemploywise.com/asperm/servlet/ggs.erm.servlet.setup3.LoginS?customer_code=chrysalishrd" class="tile">
            <img src="/images/Employwise.png" alt="Icon 2">
            <p>Employwise</p>
        </a>
        <a href="https://chrysalishrd.sharepoint.com/SitePages/Chry_Home.aspx" class="tile">
            <img src="/images/SharepointLofo.png" alt="MyChrysalis">
            <p>My Chrysalis</p>
        </a>

        <% if (canRunZohoETL) { %>
        <div class="tile" id="zohoEtlTile" onclick="runZohoETL()" style="cursor:pointer;">
            <img src="/images/logo-ic.png" alt="Zoho Export Icon">
            <p>Zoho Export</p>
            <% if (etlState && etlState.lastSuccessfulRun) { %>
            <small style="color:#fff;font-size:0.6rem;display:block;margin-top:4px;">
                Last run: <%= new Date(etlState.lastSuccessfulRun).toLocaleString('en-IN', {timeZone:'Asia/Kolkata'}) %>
            </small>
            <% if (etlState.lastRunBy) { %>
            <small style="color:#fff;font-size:0.6rem;display:block;">
                By: <%= etlState.lastRunBy %>
            </small>
            <% } %>
            <% } else { %>
            <small style="color:#fff;font-size:0.6rem;display:block;margin-top:4px;">Never run</small>
            <% } %>
            <% if (etlState.lastSuccessfulRun && etlState.recordsInserted !== undefined) { %>
            <small style="color:#fff;font-size:0.6rem;display:block;">
                Records Inserted: <%= etlState.recordsInserted %>
            </small>
            <% if (etlState.failedRecords !== undefined) { %>
            <small style="color:#fff;font-size:0.6rem;display:block;">
                Failed Records: <%= etlState.failedRecords %>
            </small>
            <% } %>
            <%  } %>
        </div>
        <% } %>
        <!-- Add more tiles as needed -->
    </div>

    <% if (canRunZohoETL) { %>
    <!-- Status overlay shown while ETL is running -->
    <div id="etlOverlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:9999;align-items:center;justify-content:center;flex-direction:column;color:#fff;font-size:1.2rem;">
        <div id="etlSpinner" style="font-size:2rem;margin-bottom:1rem;">&#8987;</div>
        <div id="etlMessage">Running Zoho Export, please wait&hellip;</div>
    </div>

    <script>
    async function runZohoETL() {
        const tile = document.getElementById('zohoEtlTile');
        const overlay = document.getElementById('etlOverlay');
        const msgEl = document.getElementById('etlMessage');

        tile.style.pointerEvents = 'none';
        tile.style.opacity = '0.6';
        overlay.style.display = 'flex';

        try {
            const res = await fetch('/zoho-etl/run', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            const data = await res.json();

            if (res.ok && data.success) {
                msgEl.textContent = 'Zoho Export completed successfully! Refreshing…';
                setTimeout(() => location.reload(), 1500);
            } else {
                msgEl.textContent = 'Export failed: ' + (data.message || 'Unknown error');
                setTimeout(() => {
                    overlay.style.display = 'none';
                    tile.style.pointerEvents = '';
                    tile.style.opacity = '';
                }, 4000);
            }
        } catch (err) {
            msgEl.textContent = 'Network error: ' + err.message;
            setTimeout(() => {
                overlay.style.display = 'none';
                tile.style.pointerEvents = '';
                tile.style.opacity = '';
            }, 4000);
        }
    }
    </script>
    <% } %>
</body>
</html>
