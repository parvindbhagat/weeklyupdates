function sectorLegend(sectors) {
  var html = '<div class="legend">';
  sectors.forEach(function(s) {
    html += '<div class="leg-item"><div class="leg-dot" style="background:'+esc(s.chart_color)+'"></div>'+esc(s.name)+'</div>';
