function metricCard(color, label, value, desc) {
  return '<div class="metric-card '+colorClass(color)+'">' +
    '<div class="mlabel">'+esc(label)+'</div>' +
    '<div class="mvalue">'+esc(value)+'</div>' +
    '<div class="mdesc">'+esc(desc)+'</div></div>';
}

