// ── Data bar ──────────────────────────────────────────────────────────────
function updateDataBar(d) {
  document.getElementById('edition-badge').textContent = d.meta.edition + ' Edition';
  document.getElementById('prepared-date').textContent = d.meta.prepared_date;
}

// ── Charts ────────────────────────────────────────────────────────────────
function renderCharts() {
  if (!REPORT) return;
  var sectors = REPORT.sectors;
  var labels  = sectors.map(function(s){ return s.name; });
  var opps    = sectors.map(function(s){ return s.chart_opportunity; });
  var emps    = sectors.map(function(s){ return s.chart_employees; });
  var aiGaps  = sectors.map(function(s){ return s.chart_ai_gap; });
  var colors  = sectors.map(function(s){ return s.chart_color; });
  var empLabels = sectors.map(function(s){ return s.name+' ('+s.chart_employees+'M)'; });

  // Sector opportunity bar
  mkChart('chartSec','bar',{labels:labels,datasets:[{label:'₹ Crores',data:opps,backgroundColor:colors,borderRadius:6,borderSkipped:false}]},{
    responsive:true,maintainAspectRatio:false,
    plugins:{legend:{display:false},tooltip:{callbacks:{label:function(v){return '₹'+v.parsed.y+' Cr';}}}},
    scales:{x:{grid:{display:false},ticks:{font:{size:11}}},y:{grid:{color:'rgba(0,0,0,0.06)'},ticks:{callback:function(v){return '₹'+v;},font:{size:11}},beginAtZero:true}}
  });

  // Employee doughnut
  mkChart('chartEmp','doughnut',{labels:empLabels,datasets:[{data:emps,backgroundColor:colors,borderWidth:2,borderColor:'#fff'}]},{
    responsive:true,maintainAspectRatio:false,cutout:'58%',
    plugins:{legend:{position:'bottom',labels:{font:{size:10},padding:8,boxWidth:10}},tooltip:{callbacks:{label:function(v){return v.label+': '+v.parsed+'M';}}}}
  });

  // AI skills gap horizontal bar
  var aiSorted = sectors.slice().sort(function(a,b){return b.chart_ai_gap - a.chart_ai_gap;});
  mkChart('chartAI','bar',
    {labels:aiSorted.map(function(s){return s.name;}),
     datasets:[{label:'AI Skills Gap (%)',data:aiSorted.map(function(s){return s.chart_ai_gap;}),backgroundColor:aiSorted.map(function(s){return s.chart_color;}),borderRadius:4}]},
    {indexAxis:'y',responsive:true,maintainAspectRatio:false,
     plugins:{legend:{display:false},tooltip:{callbacks:{label:function(v){return v.parsed.x+'%';}}}},
     scales:{x:{grid:{color:'rgba(0,0,0,0.06)'},ticks:{callback:function(v){return v+'%';},font:{size:10}},max:60},y:{grid:{display:false},ticks:{font:{size:10}}}}}
  );

  // Tier-1 pipeline pie
  var t1 = REPORT.overview.tier1_targets;
  mkChart('chartTierPie','pie',
    {labels:t1.map(function(t){return t.company;}),
     datasets:[{data:t1.map(function(_,i){return [40,35,30,25,20][i]||15;}),backgroundColor:['#E95757','#0DADB5','#FCB22B','#e07b4f','#7B68EE'],borderWidth:2,borderColor:'#fff'}]},
    {responsive:true,maintainAspectRatio:false,
     plugins:{legend:{position:'bottom',labels:{font:{size:10},padding:8,boxWidth:10}},tooltip:{callbacks:{label:function(v){return v.label+': ₹'+v.parsed+' Cr est.';}}}}}
  );

  // Tier distribution doughnut
  var total = REPORT.meta.total_companies;
  var t1count = t1.length;
  var t2count = REPORT.overview.tier2_targets.length;
  var t3count = total - t1count - t2count;
  mkChart('chartTierDist','doughnut',
    {labels:['Tier-1: Immediate ('+t1count+')','Tier-2: Active Pipeline ('+t2count+')','Tier-3: Nurture ('+t3count+')'],
     datasets:[{data:[t1count,t2count,t3count],backgroundColor:['#E95757','#FCB22B','#0DADB5'],borderWidth:2,borderColor:'#fff'}]},
    {responsive:true,maintainAspectRatio:false,cutout:'52%',
     plugins:{legend:{position:'bottom',labels:{font:{size:10},padding:8,boxWidth:10}}}}
  );
}

function mkChart(id, type, data, opts) {
  var el = document.getElementById(id);
  if (!el) return;
  if (_charts[id]) { try { _charts[id].destroy(); } catch(e){} }
  _charts[id] = new Chart(el, {type:type, data:data, options:opts});
}

// ── Nav panel switching ───────────────────────────────────────────────────
function showPanel(id, btn) {
  document.querySelectorAll('.panel').forEach(function(p){ p.classList.remove('active'); });
  document.querySelectorAll('.nav-tab').forEach(function(t){ t.classList.remove('active'); });
  var panel = document.getElementById('panel-'+id);
  if (panel) panel.classList.add('active');
  if (btn) btn.classList.add('active');
  // re-render charts if switching back to overview
  if (id === 'overview') { setTimeout(function(){ Object.values(_charts).forEach(function(c){try{c.update();}catch(e){}});}, 50); }
}

// ── Table filter ──────────────────────────────────────────────────────────
function filterTable(id, val) {
  var rows = document.querySelectorAll('#tbody-'+id+' tr');
  var q = val.toLowerCase();
  rows.forEach(function(r){ r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none'; });
  var vis = [...rows].filter(function(r){ return r.style.display !== 'none'; }).length;
  var footer = document.getElementById('footer-'+id);
  if (footer) footer.textContent = 'Showing '+vis+' of '+rows.length+' companies'+(val?' matching "'+val+'"':' · Sub-Sector shown under Company Name');
}

// ── Checkbox select ───────────────────────────────────────────────────────
function toggleSelectAll2(sector, cb) {
  document.querySelectorAll('#tbody-'+sector+' .row-cb').forEach(function(c){ c.checked = cb.checked; });
  document.querySelectorAll('#tbody-'+sector+' tr').forEach(function(r){ r.classList.toggle('row-selected', cb.checked); });
  updateSelCountDisplay(sector);
}
function toggleSelectAll(sector, btn) {
  var cbs = document.querySelectorAll('#tbody-'+sector+' .row-cb');
  var anyUnchecked = [...cbs].some(function(c){ return !c.checked; });
  cbs.forEach(function(c){ c.checked = anyUnchecked; });
  document.querySelectorAll('#tbody-'+sector+' tr').forEach(function(r){ r.classList.toggle('row-selected', anyUnchecked); });
  var hcb = document.querySelector('#ctbl-'+sector+' thead .row-cb');
  if (hcb) hcb.checked = anyUnchecked;
  btn.textContent = (anyUnchecked ? '☑' : '☐') + ' Select All';
  updateSelCountDisplay(sector);
}
function updateSelCount(cb) {
  var tr = cb.closest('tr');
  if (tr) tr.classList.toggle('row-selected', cb.checked);
  var tbody = cb.closest('tbody');
  if (!tbody) return;
  updateSelCountDisplay(tbody.id.replace('tbody-',''));
}
function updateSelCountDisplay(sector) {
  var n = [...document.querySelectorAll('#tbody-'+sector+' .row-cb')].filter(function(c){ return c.checked; }).length;
  var el = document.getElementById('selcount-'+sector);
  if (el) el.textContent = n + ' selected';
}

// ── Export modal ──────────────────────────────────────────────────────────
function openExportModal(sector, scope) {
  _expSector = sector;
  _expScope  = scope;
  document.querySelectorAll('.exp-scope-btn').forEach(function(b){ b.classList.toggle('active', b.dataset.scope === scope); });
  updateScopeCounts(sector);
  var sLabel = REPORT ? (REPORT.sectors.find(function(s){return s.id===sector;})||{name:sector}).name : sector;
  document.getElementById('expModalSub').textContent = 'Exporting from ' + sLabel;
  document.getElementById('expModalBg').classList.add('open');
}
function closeExportModal() { document.getElementById('expModalBg').classList.remove('open'); }
function setScope(btn, scope) {
  _expScope = scope;
  document.querySelectorAll('.exp-scope-btn').forEach(function(b){ b.classList.toggle('active', b === btn); });
  updateScopeCounts(_expSector);
}
function updateScopeCounts(sector) {
  var rows = [...document.querySelectorAll('#tbody-'+sector+' tr')];
  document.getElementById('scopeFilteredCount').textContent = rows.filter(function(r){ return r.style.display !== 'none'; }).length + ' rows';
  document.getElementById('scopeSelectedCount').textContent = rows.filter(function(r){ return r.querySelector('.row-cb') && r.querySelector('.row-cb').checked; }).length + ' rows';
}
function getActiveFields() {
  var f = {};
  document.querySelectorAll('.field-toggle').forEach(function(btn){ f[btn.dataset.field] = btn.classList.contains('on'); });
  return f;
}
function doExport() {
  if (!REPORT) return;
  var fields = getActiveFields();
  var header = [];
  if (fields.sn)             header.push('SN');
  if (fields.company)        header.push('Company Name');
  if (fields.subsector)      header.push('Sub-Sector');
  if (fields.primary_buyer)  header.push('Primary Contact');
  if (fields.secondary_buyers) header.push('Secondary Contact');
  if (fields.buying_signal)  header.push('Why Now (Buying Signal)');
  if (fields.hrd_themes)     header.push('Chrysalis HRD Themes');
  if (fields.sales_angle)    header.push('Chrysalis HRD Sales Angle');
  if (fields.sector)         header.push('Sector');

  var rows = [header.map(function(h){ return '"'+h+'"'; }).join(',')];
  var sectors = _expScope === 'allsectors' ? REPORT.sectors.map(function(s){return s.id;}) : [_expSector];

  sectors.forEach(function(sid) {
    var sec = REPORT.sectors.find(function(s){ return s.id === sid; });
    if (!sec) return;
    var trs = [...document.querySelectorAll('#tbody-'+sid+' tr')];
    var subset;
    if (_expScope === 'selected') {
      subset = trs.filter(function(r){ return r.querySelector('.row-cb') && r.querySelector('.row-cb').checked; });
    } else if (_expScope === 'filtered') {
      subset = trs.filter(function(r){ return r.style.display !== 'none'; });
    } else {
      subset = trs;
    }
    // get company data from REPORT (clean, no HTML)
    subset.forEach(function(tr) {
      var snCell = tr.querySelector('.sn-cell');
      var sn = snCell ? snCell.textContent.trim() : '';
      var c = sec.companies.find(function(x){ return String(x.sn) === sn; });
      if (!c) return;
      var cols = [];
      if (fields.sn)             cols.push(String(c.sn));
      if (fields.company)        cols.push(c.company);
      if (fields.subsector)      cols.push(c.subsector);
      if (fields.primary_buyer)  cols.push(c.primary_buyer);
      if (fields.secondary_buyers) cols.push(c.secondary_buyers);
      if (fields.buying_signal)  cols.push(c.buying_signal);
      if (fields.hrd_themes)     cols.push(c.hrd_themes);
      if (fields.sales_angle)    cols.push(c.sales_angle);
      if (fields.sector)         cols.push(sec.name);
      rows.push(cols.map(function(v){ return '"'+String(v).replace(/"/g,"'")+'"'; }).join(','));
    });
  });

  var csv = rows.join('\n');
  var blob = new Blob([csv], {type:'text/csv;charset=utf-8;'});
  var url  = URL.createObjectURL(blob);
  var a    = document.createElement('a');
  a.href   = url;
  a.download = 'chrysalis-hrd-' + (_expScope==='allsectors'?'all-sectors':_expSector) + '-' + _expScope + '.csv';
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
  URL.revokeObjectURL(url);
  closeExportModal();
}

// ═══════════════════════════════════════════════════════
// EMBEDDED DATA — replaced each month by loading a new JSON
// ═══════════════════════════════════════════════════════
var EMBEDDED_DATA = <%- JSON.stringify(reportdata || {}) %>;
</script>
