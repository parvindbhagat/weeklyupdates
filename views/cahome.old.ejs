<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Chrysalis HRD Market Intelligence Report</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
/* ═══════════════════════════════════════════════════════
   CHRYSALIS HRD — REPORT TEMPLATE v1.0
   Brand colours: Red #E95757 · Yellow #FCB22B · Blue #0DADB5
   Font: Century Gothic 16px
   Theme: Light only
   ─────────────────────────────────────────────────
   DO NOT EDIT BELOW THIS BLOCK for monthly updates.
   All content is driven from chrysalis_hrd_data_YYYY.json
   ═══════════════════════════════════════════════════════ */
@font-face{font-family:"Century Gothic";src:local("Century Gothic"),local("CenturyGothic");}
:root{
  --red:#E95757; --yellow:#FCB22B; --blue:#0DADB5;
  --red-light:#fdf0f0; --yellow-light:#fffbf0; --blue-light:#eefafb;
  --red-dark:#c03f3f; --yellow-dark:#c4860a; --blue-dark:#0a8a91;
  --text:#1a1a2e; --text-muted:#5a5a7a;
  --bg:#f4f5f8; --surface:#ffffff; --border:#e2e4ec;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:"Century Gothic","CenturyGothic",AppleGothic,Futura,sans-serif;font-size:16px;background:var(--bg);color:var(--text);line-height:1.6;}

/* ── LOADER ── */
#loader{position:fixed;inset:0;background:#fff;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:9999;gap:16px;}
#loader .logo{font-size:22px;font-weight:700;color:var(--red);}
#loader .bar{width:200px;height:4px;background:#f0f0f0;border-radius:4px;overflow:hidden;}
#loader .bar-fill{height:100%;background:linear-gradient(90deg,var(--red),var(--yellow),var(--blue));animation:lbar 1.4s ease-in-out infinite;}
@keyframes lbar{0%{width:0;transform:translateX(0)}60%{width:100%}100%{width:100%;transform:translateX(100%)}}
#loader .msg{font-size:13px;color:var(--text-muted);}

/* ── HEADER ── */
.header{background:var(--red);position:relative;overflow:hidden;}
.header::before{content:"";position:absolute;top:-80px;right:-80px;width:320px;height:320px;background:rgba(252,178,43,.15);border-radius:50%;}
.header::after{content:"";position:absolute;bottom:-60px;left:5%;width:220px;height:220px;background:rgba(13,173,181,.12);border-radius:50%;}
.header-inner{max-width:1500px;margin:0 auto;padding:40px 40px 32px;position:relative;z-index:1;display:flex;justify-content:space-between;align-items:flex-end;gap:28px;flex-wrap:wrap;}
.header-badge{display:inline-block;background:rgba(252,178,43,.22);border:1px solid rgba(252,178,43,.45);color:#FCB22B;font-size:10px;letter-spacing:2px;text-transform:uppercase;padding:4px 14px;border-radius:20px;margin-bottom:12px;}
.header h1{font-size:26px;font-weight:700;color:#fff;line-height:1.25;margin-bottom:7px;}
.header h1 span{color:#FCB22B;}
.header-sub{color:rgba(255,255,255,.78);font-size:13px;}
.header-stats{display:flex;gap:14px;flex-wrap:wrap;}
.hstat{background:rgba(255,255,255,.13);border:1px solid rgba(255,255,255,.22);border-radius:10px;padding:13px 18px;text-align:center;min-width:100px;}
.hstat .val{display:block;font-size:20px;font-weight:700;color:#FCB22B;line-height:1;margin-bottom:5px;}
.hstat .lbl{font-size:10px;color:rgba(255,255,255,.7);text-transform:uppercase;letter-spacing:.5px;}

/* ── DATA LOAD TOOLBAR ── */
.data-bar{background:#1a1a2e;padding:8px 40px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;}
.data-bar-label{font-size:11px;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:1px;}
.data-bar select,.data-bar input[type=file]{padding:5px 10px;border-radius:6px;border:1px solid rgba(255,255,255,.2);background:rgba(255,255,255,.08);color:#fff;font-family:inherit;font-size:11px;cursor:pointer;}
.data-bar select option{background:#1a1a2e;color:#fff;}
.data-bar .edition-badge{background:rgba(252,178,43,.25);border:1px solid rgba(252,178,43,.4);color:#FCB22B;font-size:11px;font-weight:700;padding:3px 12px;border-radius:12px;}
.data-bar .sep{color:rgba(255,255,255,.2);font-size:14px;}
.btn-load-json{padding:5px 14px;border-radius:6px;border:1px solid rgba(13,173,181,.5);background:rgba(13,173,181,.15);color:#0DADB5;font-family:inherit;font-size:11px;font-weight:700;cursor:pointer;transition:all .15s;}
.btn-load-json:hover{background:rgba(13,173,181,.3);}

/* ── NAV ── */
.nav-bar{background:var(--surface);border-bottom:2px solid var(--border);position:sticky;top:0;z-index:200;box-shadow:0 2px 8px rgba(0,0,0,.07);}
.nav-inner{max-width:1500px;margin:0 auto;padding:0 40px;display:flex;overflow-x:auto;scrollbar-width:none;}
.nav-inner::-webkit-scrollbar{display:none;}
.nav-tab{padding:14px 16px;font-family:inherit;font-size:12.5px;font-weight:700;border:none;background:none;cursor:pointer;color:var(--text-muted);border-bottom:3px solid transparent;margin-bottom:-2px;white-space:nowrap;transition:color .2s,border-color .2s;flex-shrink:0;}
.nav-tab:hover{color:var(--red);}
.nav-tab.active{color:var(--red);border-bottom-color:var(--red);}

/* ── MAIN ── */
.main{max-width:1500px;margin:0 auto;padding:28px 40px;}
.panel{display:none;}.panel.active{display:block;}

/* ── SECTION HEADERS ── */
.section-title{font-size:18px;font-weight:700;color:var(--text);margin-bottom:4px;display:flex;align-items:center;gap:10px;margin-top:28px;}
.section-title:first-child{margin-top:0;}
.section-title::before{content:"";display:inline-block;width:5px;height:20px;background:var(--red);border-radius:3px;flex-shrink:0;}
.section-sub{font-size:13px;color:var(--text-muted);margin-bottom:20px;padding-left:15px;}

/* ── METRIC CARDS ── */
.metrics-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:28px;}
.metric-card{background:var(--surface);border-radius:12px;padding:20px 18px 16px;border:1px solid var(--border);box-shadow:0 2px 8px rgba(0,0,0,.05);position:relative;overflow:hidden;}
.metric-card::after{content:"";position:absolute;bottom:0;left:0;right:0;height:4px;}
.mc-red::after{background:var(--red);}.mc-yellow::after{background:var(--yellow);}.mc-blue::after{background:var(--blue);}.mc-tri::after{background:linear-gradient(90deg,var(--red),var(--yellow),var(--blue));}
.mlabel{font-size:10px;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);margin-bottom:7px;}
.mvalue{font-size:24px;font-weight:700;line-height:1;margin-bottom:6px;}
.mc-red .mvalue{color:var(--red);}.mc-yellow .mvalue{color:var(--yellow-dark);}.mc-blue .mvalue{color:var(--blue-dark);}.mc-tri .mvalue{color:var(--red);}
.mdesc{font-size:11.5px;color:var(--text-muted);line-height:1.5;}

/* ── CHARTS ── */
.chart-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:28px;}
.chart-grid-w{display:grid;grid-template-columns:3fr 2fr;gap:20px;margin-bottom:28px;}
.chart-card{background:var(--surface);border-radius:12px;padding:20px;border:1px solid var(--border);box-shadow:0 2px 8px rgba(0,0,0,.05);}
.chart-card-title{font-size:13px;font-weight:700;color:var(--text);margin-bottom:14px;display:flex;justify-content:space-between;align-items:center;}
.cpill{font-size:10px;padding:2px 9px;border-radius:14px;background:var(--red-light);color:var(--red);}
.cpill.b{background:var(--blue-light);color:var(--blue-dark);}.cpill.y{background:var(--yellow-light);color:var(--yellow-dark);}
.legend{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:12px;font-size:11.5px;color:var(--text-muted);}
.leg-item{display:flex;align-items:center;gap:5px;}
.leg-dot{width:9px;height:9px;border-radius:2px;flex-shrink:0;}

/* ── HW GRID ── */
.hw-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:28px;}
.hw-card{background:var(--surface);border-radius:12px;border:1px solid var(--border);overflow:hidden;box-shadow:0 2px 6px rgba(0,0,0,.04);}
.hw-head{padding:13px 17px;font-weight:700;font-size:12.5px;display:flex;align-items:center;gap:7px;}
.hw-head.tw{background:var(--blue-light);color:var(--blue-dark);}.hw-head.hw{background:var(--red-light);color:var(--red-dark);}
.hw-row{padding:10px 17px;border-bottom:1px solid var(--border);display:flex;gap:9px;}
.hw-row:last-child{border-bottom:none;}
.hw-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;margin-top:5px;}
.hw-dot.t{background:var(--blue);}.hw-dot.h{background:var(--red);}
.hwtitle{font-size:12px;font-weight:700;color:var(--text);margin-bottom:2px;}
.hwdesc{font-size:11px;color:var(--text-muted);line-height:1.5;}

/* ── INSIGHT CARDS ── */
.insight-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:28px;}
.insight-card{background:var(--surface);border-radius:12px;border:1px solid var(--border);padding:18px;box-shadow:0 2px 6px rgba(0,0,0,.04);}
.ins-icon{font-size:20px;margin-bottom:10px;}
.ins-title{font-size:12.5px;font-weight:700;color:var(--text);margin-bottom:6px;}
.ins-text{font-size:12px;color:var(--text-muted);line-height:1.6;}

/* ── COMPANY TABLE ── */
.tbl-wrap{background:var(--surface);border-radius:12px;border:1px solid var(--border);box-shadow:0 2px 8px rgba(0,0,0,.05);overflow:hidden;margin-bottom:28px;}
.tbl-top{padding:14px 18px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;}
.tbl-top-title{font-size:14px;font-weight:700;color:var(--text);}
.tbl-controls{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.tbl-search{padding:7px 13px;border:1px solid var(--border);border-radius:8px;font-family:inherit;font-size:12px;outline:none;width:220px;}
.tbl-search:focus{border-color:var(--red);}
.export-bar{display:flex;align-items:center;gap:6px;background:#fff;border:1px solid var(--border);border-radius:10px;padding:6px 10px;flex-wrap:wrap;}
.export-bar-label{font-size:11px;font-weight:700;color:var(--text-muted);white-space:nowrap;}
.btn-exp{display:inline-flex;align-items:center;gap:5px;padding:5px 12px;border-radius:7px;border:1px solid var(--border);font-family:inherit;font-size:11.5px;font-weight:700;cursor:pointer;background:var(--surface);color:var(--text);transition:all .15s;white-space:nowrap;}
.btn-exp:hover{background:var(--red);color:#fff;border-color:var(--red);}
.btn-exp svg{width:13px;height:13px;flex-shrink:0;}
.btn-sel-all{padding:5px 11px;border-radius:7px;border:1px solid var(--border);font-family:inherit;font-size:11px;font-weight:700;cursor:pointer;background:var(--surface);color:var(--text-muted);transition:all .15s;white-space:nowrap;}
.btn-sel-all:hover{background:var(--yellow-light);border-color:var(--yellow);color:var(--yellow-dark);}
.sel-count{font-size:11px;color:var(--blue-dark);font-weight:700;white-space:nowrap;min-width:60px;}
.tbl-scroll{overflow-x:auto;}
table.ctbl{width:100%;border-collapse:collapse;font-size:12px;}
.ctbl th{background:#f1f2f7;padding:9px 12px;text-align:left;font-size:10px;text-transform:uppercase;letter-spacing:.7px;color:var(--text-muted);font-weight:700;white-space:nowrap;}
.ctbl td{padding:10px 12px;border-bottom:1px solid var(--border);vertical-align:top;line-height:1.4;}
.ctbl tr:last-child td{border-bottom:none;}
.ctbl tr:hover td{background:#f8f9fc;}
.ctbl .cb-col{width:32px;text-align:center;padding:8px 6px;}
.ctbl th.cb-col{background:#f1f2f7;}
.row-cb{width:14px;height:14px;accent-color:var(--red);cursor:pointer;}
.ctbl tr.row-selected td{background:rgba(233,87,87,.06);}
.sn-cell{font-weight:700;color:var(--text-muted);font-size:11px;text-align:center;min-width:28px;}
.co-name{font-weight:700;color:var(--text);font-size:12.5px;margin-bottom:2px;}
.co-sub{font-size:10.5px;color:var(--text-muted);}
.buyer-name{font-weight:700;color:var(--blue-dark);font-size:11.5px;margin-bottom:2px;}
.buyer-role{font-size:10.5px;color:var(--text-muted);}
.signal-tag{display:inline-block;font-size:10px;padding:2px 7px;border-radius:9px;background:#fff3cd;color:#856404;line-height:1.4;margin-bottom:2px;}
.signal-hot{display:inline-block;font-size:10px;padding:2px 7px;border-radius:9px;background:var(--red-light);color:var(--red-dark);line-height:1.4;margin-bottom:2px;font-weight:700;}
.theme-tag{display:inline-block;font-size:10px;padding:1px 6px;border-radius:7px;background:var(--blue-light);color:var(--blue-dark);margin:1px 2px 1px 0;line-height:1.4;}
.angle-text{font-size:11px;color:var(--text);font-style:italic;line-height:1.5;}
.tbl-footer{padding:9px 18px;background:#f8f9fc;border-top:1px solid var(--border);font-size:11px;color:var(--text-muted);}

/* ── TIER TABLES ── */
.tier-tbl-wrap{background:var(--surface);border-radius:12px;border:1px solid var(--border);overflow:hidden;margin-bottom:22px;box-shadow:0 2px 6px rgba(0,0,0,.05);}
.tier-tbl-head{padding:14px 18px;border-bottom:1px solid var(--border);font-size:14px;font-weight:700;color:var(--text);}
.tier-badge{display:inline-block;font-size:10px;font-weight:700;padding:2px 8px;border-radius:11px;}
.t1{background:var(--red-light);color:var(--red);}.t2{background:var(--yellow-light);color:var(--yellow-dark);}.t3{background:var(--blue-light);color:var(--blue-dark);}

/* ── TIMELINE ── */
.timeline{position:relative;padding-left:28px;margin-bottom:26px;}
.timeline::before{content:"";position:absolute;left:6px;top:8px;bottom:8px;width:2px;background:linear-gradient(to bottom,var(--red),var(--yellow),var(--blue));border-radius:2px;}
.tl-item{position:relative;margin-bottom:14px;background:var(--surface);border-radius:10px;border:1px solid var(--border);padding:13px 17px;}
.tl-item::before{content:"";position:absolute;left:-23px;top:15px;width:11px;height:11px;border-radius:50%;border:2px solid #fff;}
.tl-r::before{background:var(--red);box-shadow:0 0 0 2px var(--red);}
.tl-y::before{background:var(--yellow);box-shadow:0 0 0 2px var(--yellow);}
.tl-b::before{background:var(--blue);box-shadow:0 0 0 2px var(--blue);}
.tl-company{font-weight:700;font-size:14px;color:var(--text);}
.tl-role{font-size:11.5px;margin-bottom:3px;}
.tl-role.r{color:var(--red);}.tl-role.y{color:var(--yellow-dark);}.tl-role.b{color:var(--blue-dark);}
.tl-detail{font-size:11.5px;color:var(--text-muted);}

/* ── EXPORT MODAL ── */
.exp-modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:9999;align-items:center;justify-content:center;}
.exp-modal-bg.open{display:flex;}
.exp-modal{background:#fff;border-radius:16px;padding:28px 30px;width:440px;max-width:94vw;box-shadow:0 12px 40px rgba(0,0,0,.18);font-family:"Century Gothic","CenturyGothic",AppleGothic,Futura,sans-serif;}
.exp-modal-title{font-size:16px;font-weight:700;color:var(--text);margin-bottom:4px;}
.exp-modal-sub{font-size:12px;color:var(--text-muted);margin-bottom:18px;}
.exp-modal-section{font-size:11px;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);font-weight:700;margin-bottom:8px;}
.exp-scope-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:18px;}
.exp-scope-btn{padding:9px 12px;border-radius:8px;border:1.5px solid var(--border);font-family:inherit;font-size:12px;font-weight:700;cursor:pointer;background:#fff;color:var(--text);transition:all .15s;text-align:left;}
.exp-scope-btn:hover,.exp-scope-btn.active{background:var(--red-light);border-color:var(--red);color:var(--red-dark);}
.exp-scope-btn small{display:block;font-weight:400;font-size:10.5px;color:var(--text-muted);margin-top:2px;}
.exp-scope-btn.active small{color:var(--red);}
.exp-fields{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:18px;}
.field-toggle{padding:4px 10px;border-radius:6px;border:1px solid var(--border);font-family:inherit;font-size:11px;cursor:pointer;background:#fff;color:var(--text-muted);transition:all .15s;}
.field-toggle.on{background:var(--blue-light);border-color:var(--blue);color:var(--blue-dark);font-weight:700;}
.exp-modal-actions{display:flex;gap:10px;justify-content:flex-end;margin-top:4px;}
.btn-cancel{padding:8px 18px;border-radius:8px;border:1px solid var(--border);font-family:inherit;font-size:13px;cursor:pointer;background:#fff;color:var(--text-muted);}
.btn-cancel:hover{background:var(--bg);}
.btn-dl{padding:8px 20px;border-radius:8px;border:none;font-family:inherit;font-size:13px;font-weight:700;cursor:pointer;background:var(--red);color:#fff;transition:background .15s;}
.btn-dl:hover{background:var(--red-dark);}

/* ── SALES NOTE ── */
.sales-note{background:var(--red-light);border:1px solid var(--red);border-radius:12px;padding:20px 22px;margin-bottom:28px;}
.sales-note-title{font-weight:700;color:var(--red);font-size:14px;margin-bottom:8px;}
.sales-note-body{font-size:12px;color:var(--text);line-height:1.9;}

/* ── FOOTER ── */
footer{background:var(--text);color:rgba(255,255,255,.6);padding:22px 40px;font-size:11.5px;margin-top:32px;}
.foot-inner{max-width:1500px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:9px;}
footer strong{color:#FCB22B;}

/* ── RESPONSIVE ── */
@media(max-width:1100px){
  .metrics-grid{grid-template-columns:repeat(2,1fr);}
  .chart-grid,.chart-grid-w,.hw-grid{grid-template-columns:1fr;}
  .insight-grid{grid-template-columns:repeat(2,1fr);}
}
@media(max-width:700px){
  .main{padding:16px;}
  .metrics-grid,.insight-grid{grid-template-columns:1fr;}
  .header-inner{flex-direction:column;align-items:flex-start;}
  .data-bar{padding:8px 16px;}
  .nav-inner{padding:0 12px;}
}
</style>
</head>
<body>

<!-- LOADER -->
<div id="loader">
  <div class="logo">Chrysalis HRD</div>
  <div class="bar"><div class="bar-fill"></div></div>
  <div class="msg" id="loader-msg">Loading report data…</div>
</div>

<!-- DYNAMIC HEADER (rendered by JS) -->
<div id="app-header"></div>

<!-- DATA BAR -->
<div class="data-bar">
  <span class="data-bar-label">Data Source:</span>
  <span class="edition-badge" id="edition-badge">2026 Edition</span>
  <span class="sep">|</span>
  <span class="data-bar-label">Load different month:</span>
  <input type="file" id="json-file-input" accept=".json" title="Upload a monthly JSON data file">
  <button class="btn-load-json" onclick="document.getElementById('json-file-input').click()">📂 Load JSON</button>
  <span class="sep">|</span>
  <span class="data-bar-label">Last updated: <span id="prepared-date">—</span></span>
</div>

<!-- NAV TABS (rendered by JS) -->
<div class="nav-bar"><div class="nav-inner" id="nav-tabs"></div></div>

<!-- PANELS (rendered by JS) -->
<div class="main" id="main-panels"></div>

<!-- FOOTER (rendered by JS) -->
<div id="app-footer"></div>

<!-- EXPORT MODAL -->
<div class="exp-modal-bg" id="expModalBg" onclick="if(event.target===this)closeExportModal()">
  <div class="exp-modal">
    <div class="exp-modal-title">Export to CSV</div>
    <div class="exp-modal-sub" id="expModalSub">Configure export options below</div>
    <div class="exp-modal-section">Scope</div>
    <div class="exp-scope-grid" id="expScopeGrid">
      <button class="exp-scope-btn active" data-scope="filtered" onclick="setScope(this,'filtered')">Filtered / Visible<small id="scopeFilteredCount">— rows</small></button>
      <button class="exp-scope-btn" data-scope="selected" onclick="setScope(this,'selected')">Selected (checked)<small id="scopeSelectedCount">— rows</small></button>
      <button class="exp-scope-btn" data-scope="all" onclick="setScope(this,'all')">All rows in sector<small>Full sector list</small></button>
      <button class="exp-scope-btn" data-scope="allsectors" onclick="setScope(this,'allsectors')">All 300 companies<small>Every sector combined</small></button>
    </div>
    <div class="exp-modal-section">Columns to Include</div>
    <div class="exp-fields" id="expFields">
      <button class="field-toggle on" data-field="sn">SN</button>
      <button class="field-toggle on" data-field="company">Company Name</button>
      <button class="field-toggle on" data-field="subsector">Sub-Sector</button>
      <button class="field-toggle on" data-field="primary_buyer">Primary Contact</button>
      <button class="field-toggle on" data-field="secondary_buyers">Secondary Contact</button>
      <button class="field-toggle on" data-field="buying_signal">Buying Signal</button>
      <button class="field-toggle on" data-field="hrd_themes">Chrysalis HRD Themes</button>
      <button class="field-toggle on" data-field="sales_angle">Chrysalis HRD Sales Angle</button>
      <button class="field-toggle on" data-field="sector">Sector</button>
    </div>
    <div class="exp-modal-actions">
      <button class="btn-cancel" onclick="closeExportModal()">Cancel</button>
      <button class="btn-dl" onclick="doExport()">⬇ Download CSV</button>
    </div>
  </div>
</div>

<script>
/* ═══════════════════════════════════════════════════════
   CHRYSALIS HRD REPORT TEMPLATE ENGINE
   Version 1.0 — June 2026
   ─────────────────────────────────────────────────────
   HOW TO USE FOR MONTHLY UPDATES:
   1. Open your monthly JSON file (chrysalis_hrd_data_YYYY_MM.json)
   2. Click "Load JSON" in the data bar above
   3. The entire report re-renders from the new data
   4. No code changes needed — only the JSON changes

   JSON SCHEMA (required fields):
   ─────────────────────────────
   {
     "meta": { edition, prepared_date, total_opportunity,
               total_companies, total_employees, new_chros,
               sectors_count, immediate_window, tier1_pipeline },
     "overview": { headline, metrics[], cross_sector_insights[],
                   chro_timeline[], tier1_targets[], tier2_targets[],
                   recommendations[] },
     "sectors": [{
       id, name, full_name, subtitle, opportunity, employees,
       chart_opportunity, chart_employees, chart_ai_gap, chart_color,
       metrics[], tailwinds[], headwinds[],
       companies: [{
         sn, company, subsector, primary_buyer, secondary_buyers,
         buying_signal, hrd_themes, sales_angle, hot
       }]
     }]
   }
   ═══════════════════════════════════════════════════════ */

// ── Global state ──────────────────────────────────────────────────────────
var REPORT = null;
var _charts = {};
var _expSector = '';
var _expScope  = 'filtered';

// ── Bootstrap: load embedded JSON or from file ────────────────────────────
window.addEventListener('DOMContentLoaded', function() {
  // Wire up file input
  document.getElementById('json-file-input').addEventListener('change', function(e) {
    var file = e.target.files[0];
    if (!file) return;
    setLoaderMsg('Loading ' + file.name + '…');
    showLoader();
    var reader = new FileReader();
    reader.onload = function(ev) {
      try {
        var data = JSON.parse(ev.target.result);
        renderReport(data);
      } catch(err) {
        hideLoader();
        alert('Invalid JSON file: ' + err.message);
      }
    };
    reader.readAsText(file);
  });

  // Field toggles
  document.querySelectorAll('.field-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() { this.classList.toggle('on'); });
  });

  // Load embedded data
  setLoaderMsg('Loading report data…');
  renderReport(EMBEDDED_DATA);
});

// ── Loader helpers ────────────────────────────────────────────────────────
function showLoader() { document.getElementById('loader').style.display = 'flex'; }
function hideLoader() { document.getElementById('loader').style.display = 'none'; }
function setLoaderMsg(msg) { document.getElementById('loader-msg').textContent = msg; }

// ── Main render entry ─────────────────────────────────────────────────────
function renderReport(data) {
  REPORT = data;
  if (!data || !data.meta || !Array.isArray(data.sectors)) {
    setLoaderMsg('No report data available. Upload a valid JSON file or import data first.');
    return hideLoader();
  }

  setLoaderMsg('Building layout…');

  // destroy old charts
  Object.values(_charts).forEach(function(c) { try { c.destroy(); } catch(e){} });
  _charts = {};

  renderHeader(data);
  renderNav(data);
  renderAllPanels(data);
  renderFooter(data);
  updateDataBar(data);

  setTimeout(renderCharts, 80);
  setTimeout(hideLoader, 200);
}

// ── Utility ───────────────────────────────────────────────────────────────
function esc(s) {
  if (s == null) return '';
  return String(s)
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function colorClass(c) {
  var m = {red:'mc-red',yellow:'mc-yellow',blue:'mc-blue',tri:'mc-tri'};
  return m[c] || 'mc-red';
}

// ── Header ────────────────────────────────────────────────────────────────
function renderHeader(d) {
  var m = d.meta;
  document.getElementById('app-header').innerHTML =
    '<div class="header"><div class="header-inner"><div>' +
    '<div class="header-badge">Market Intelligence Report ' + esc(m.edition) + '</div>' +
    '<h1>Chrysalis HRD <span>Market Intelligence</span></h1>' +
    '<p class="header-sub">'+esc(m.total_companies)+' Strategic Targets &middot; '+esc(m.sectors_count)+' Priority Sectors &middot; Complete Decision-Maker Mapping &middot; Prepared '+esc(m.prepared_date)+'</p>' +
    '</div><div class="header-stats">' +
    hstat(m.total_opportunity,'Total Opportunity') +
    hstat(m.total_companies,'Target Companies') +
    hstat(m.total_employees,'Employees') +
    hstat(m.new_chros,'New CHROs') +
    hstat(m.sectors_count,'Sectors') +
    hstat(m.immediate_window,'Imm. Window') +
    '</div></div></div>';
}
function hstat(val,lbl) {
  return '<div class="hstat"><span class="val">'+esc(val)+'</span><span class="lbl">'+esc(lbl)+'</span></div>';
}

// ── Nav ───────────────────────────────────────────────────────────────────
function renderNav(d) {
  var html = '<button class="nav-tab active" onclick="showPanel(\'overview\',this)">Overview</button>';
  d.sectors.forEach(function(s) {
    html += '<button class="nav-tab" onclick="showPanel(\''+esc(s.id)+'\',this)">'+esc(s.name)+' ('+s.companies.length+')</button>';
  });
  html += '<button class="nav-tab" onclick="showPanel(\'targets\',this)">Priority Targets</button>';
  document.getElementById('nav-tabs').innerHTML = html;
}

// ── All Panels ────────────────────────────────────────────────────────────
function renderAllPanels(d) {
  var html = '';
  html += renderOverviewPanel(d);
  d.sectors.forEach(function(s) { html += renderSectorPanel(s); });
  html += renderTargetsPanel(d);
  document.getElementById('main-panels').innerHTML = html;
}

